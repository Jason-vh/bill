# Written by .github/workflows/deploy.yml from GitHub Actions secrets.
# This file shows the shape only — never commit real values.

# Authenticates the server to YNAB (a YNAB personal access token).
YNAB_ACCESS_TOKEN=replace-me
# Static bearer token clients may present to our MCP server.
MCP_BEARER_TOKEN=replace-me
# Password for the OAuth login flow (username defaults to "json").
OAUTH_LOGIN_PASSWORD=replace-me
# Signing secret for issued OAuth sessions/tokens. Keep stable across deploys.
OAUTH_SESSION_SECRET=replace-me

PUBLIC_BASE_URL=https://ynab.mcp.vhtm.eu
OAUTH_LOGIN_USERNAME=json
MCP_APP_HOST_PORT=3008
COMPOSE_PROJECT_NAME=mcp
